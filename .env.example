# ========================================
# JobSite — Environment Variables
# ========================================

# Google Gemini API Key (required)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub repository URL (optional — overrides settings.yaml)
# Set this to enable automatic git push to your GitHub Pages repo
# Example: GITHUB_REPO_URL=https://github.com/yourusername/bd-jobs.git
# GITHUB_REPO_URL=